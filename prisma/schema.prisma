generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Student {
  id                String             @id @default(auto()) @map("_id") @db.ObjectId
  admission_number  String             @unique
  full_name         String
  grade_level       String
  card_uid          String?            @unique
  wallet_balance    Float?             @default(0.00)
  created_at        DateTime?          @default(now())
  attendance        Attendance[]
  feeTransactions   FeeTransaction[]
  parentStudentMaps ParentStudentMap[]
  cards             Cards[]

  @@map("students")
}

model Parent {
  id                String             @id @default(auto()) @map("_id") @db.ObjectId
  user_id           String?
  full_name         String
  phone_number      String?            @unique
  email             String?            @unique
  created_at        DateTime?          @default(now())
  appointments      Appointment[]
  parentStudentMaps ParentStudentMap[]

  @@map("parents")
}

model Staff {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  user_id           String?
  full_name         String
  subject_specialty String?
  role              String?       @default("teacher")
  created_at        DateTime?     @default(now())
  appointments      Appointment[]
  assignments       Assignment[]

  @@map("staff")
}

model ParentStudentMap {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  parent_id    String  @db.ObjectId
  student_id   String  @db.ObjectId
  relationship String?
  parent       Parent  @relation(fields: [parent_id], references: [id], onDelete: Cascade)
  student      Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([parent_id, student_id])
  @@map("parent_student_map")
}

model Attendance {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  student_id String?   @db.ObjectId
  check_type String?
  device_id  String?
  created_at DateTime? @default(now())
  student    Student?  @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@map("attendance")
}

model FeeTransaction {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  student_id  String?   @db.ObjectId
  amount      Float
  type        String?
  description String?
  created_at  DateTime? @default(now())
  student     Student?  @relation(fields: [student_id], references: [id])

  @@map("fee_transactions")
}

model Assignment {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  teacher_id  String?   @db.ObjectId
  title       String
  description String?
  grade_level String
  due_date    DateTime
  status      String?   @default("active")
  created_at  DateTime? @default(now())
  teacher     Staff?    @relation(fields: [teacher_id], references: [id])

  @@map("assignments")
}

model Appointment {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  parent_id    String?   @db.ObjectId
  teacher_id   String?   @db.ObjectId
  scheduled_at DateTime
  status       String?   @default("pending")
  parent_notes String?
  created_at   DateTime? @default(now())
  parent       Parent?   @relation(fields: [parent_id], references: [id])
  teacher      Staff?    @relation(fields: [teacher_id], references: [id])

  @@map("appointments")
}

model Cards {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String   @unique
  student_id String?  @db.ObjectId
  student    Student? @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@map("cards")
}

enum StaffRole {
  ADMIN
  TEACHER
  ACCOUNTANT
}

enum DevicePurpose {
  ATTENDANCE
  CANTEEN
  CLEARANCE
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum CheckType {
  IN
  OUT
}

enum AttendanceStatus {
  ON_TIME
  LATE
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
}

enum GradeType {
  EXAM
  QUIZ
  ASSIGNMENT
  PROJECT
  PARTICIPATION
}
